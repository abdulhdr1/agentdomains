{
  "name": "agentdomains",
  "version": "0.1.0",
  "description": "An API for agents to find available domains to buy. RDAP-backed, no API keys.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "agentdomains": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp.ts",
    "cli": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "update-prices": "bun run scripts/update-prices.ts",
    "cf:dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
